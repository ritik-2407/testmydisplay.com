---
interface Props {
  title: string;
  description?: string;
  href: string;
  icon: string;
  tag?: string;
}

const { title, href, icon, tag } = Astro.props;
---

<a href={href} class="test-card">
  <div class="test-card-icon" aria-hidden="true" set:html={icon} />
  <div class="test-card-body">
    <h3 class="test-card-title">{title}</h3>
    {tag && <span class="test-card-tag">{tag}</span>}
  </div>
  <div class="test-card-arrow" aria-hidden="true">
    <svg width="18" height="18" viewBox="0 0 16 16" fill="none">
      <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </div>
</a>

<style>
  .test-card {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 14px 18px;
    background-color: var(--bg);
    border-radius: 14px;
    border: 1.5px solid var(--border);
    box-shadow: var(--card-shadow);
    text-decoration: none;
    transition: box-shadow 0.2s ease, transform 0.2s ease, border-color 0.2s ease, background-color 0.2s ease;
    position: relative;
    overflow: hidden;
  }

  .test-card:hover {
    box-shadow: var(--card-shadow-hover);
    border-color: var(--accent-border);
    transform: translateY(-2px);
  }

  .test-card:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .test-card-icon {
    width: 44px;
    height: 44px;
    border-radius: 10px;
    background: var(--bg-soft-2);
    border: 1.5px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: var(--text-body);
    transition: background-color 0.2s ease, color 0.2s ease, border-color 0.2s ease;
  }

  .test-card:hover .test-card-icon {
    background: var(--accent-dim);
    border-color: var(--accent-border);
    color: var(--accent);
  }

  .test-card-body {
    flex: 1;
    min-width: 0;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .test-card-title {
    font-size: 19px;
    font-weight: 600;
    color: var(--text);
    margin: 0;
    letter-spacing: -0.5px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .test-card-tag {
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 10px;
    color: var(--accent);
    background: var(--accent-dim);
    border: 1px solid var(--accent-border);
    border-radius: 9999px;
    padding: 0 7px;
    height: 20px;
    display: inline-flex;
    align-items: center;
    flex-shrink: 0;
    letter-spacing: 0.04em;
    font-weight: 500;
  }

  .test-card-arrow {
    color: var(--text-mute);
    flex-shrink: 0;
    transition: transform 0.2s ease, color 0.2s ease;
  }

  .test-card:hover .test-card-arrow {
    transform: translateX(4px);
    color: var(--accent);
  }
</style>
