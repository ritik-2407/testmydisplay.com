---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  keywords?: string;
  ogImage?: string;
  ogType?: string;
  canonical?: string;
  fullscreen?: boolean;
  noFooter?: boolean;
  bodyClass?: string;
  jsonLd?: object | object[];
}

const {
  title = 'Display Test — Free Online Display Test Tool | TestMyDisplay',
  description = 'Free online display test tool. Check dead pixels, touch screen, refresh rate, backlight bleed, response time & more. Works on mobile, OLED, AMOLED, iPhone & all screens.',
  keywords = 'display test, display test online, screen test, monitor display test, mobile display test, oled display test, amoled display test, iphone display test, color display test, screen display test, touch screen test, dead pixel check, backlight bleed test, refresh rate test',
  ogImage = 'https://testmydislay.com/og-image.png',
  ogType = 'website',
  canonical,
  fullscreen = false,
  noFooter = false,
  bodyClass = '',
  jsonLd,
} = Astro.props;

const canonicalUrl = canonical ?? Astro.url.href;
const siteName = 'TestMyDisplay';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Primary SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={`${siteName} — ${title}`} />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={`${siteName} — ${title}`} />

    <!-- Favicons & PWA -->
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="Display Test" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400&display=swap" rel="stylesheet" />
    <link href="https://fonts.cdnfonts.com/css/huitside" rel="stylesheet" />

    <!-- JSON-LD Structured Data -->
    {jsonLd && Array.isArray(jsonLd)
      ? jsonLd.map((ld) => <script type="application/ld+json" set:html={JSON.stringify(ld)} />)
      : jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    }

    <!-- Inline theme init: runs before CSS to prevent flash of wrong theme -->
    <script is:inline>
      (function () {
        var stored = localStorage.getItem('theme');
        var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        var theme = stored ? stored : (prefersDark ? 'dark' : 'light');
        document.documentElement.setAttribute('data-theme', theme);
      })();
    </script>
  </head>
  <body class={bodyClass}>
    {!fullscreen && <Navbar />}
    <main class={fullscreen ? 'fullscreen-main' : 'page-main'}>
      <slot />
    </main>
    {!fullscreen && !noFooter && <Footer />}
  </body>
</html>

<style>
  .page-main {
    min-height: calc(100vh - 280px);
    padding-top: 80px;
  }
  .fullscreen-main {
    min-height: 100vh;
  }
</style>
