---
import Layout from '../layouts/Layout.astro';
import TestCard from '../components/TestCard.astro';

const seoTitle = 'Display Test — Free Online Display Test Tool | TestMyDisplay';
const seoDescription = 'Run a free online display test right in your browser. Check dead pixels, touch screen accuracy, refresh rate, backlight bleed & more. Works on mobile, OLED, AMOLED, iPhone, and all monitors.';
const seoKeywords = 'display test, display test online, screen test, monitor display test, mobile display test, oled display test, amoled display test, iphone display test, color display test, screen display test, touch screen test, oled screen test, dead pixel check, backlight bleed test, refresh rate test, response time test';

const homeJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "TestMyDisplay",
  "url": "https://testmydislay.com",
  "description": seoDescription,
  "potentialAction": {
    "@type": "SearchAction",
    "target": "https://testmydislay.com/?q={search_term_string}",
    "query-input": "required name=search_term_string"
  }
};

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Display Tests",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Touch Screen Test", "url": "https://testmydislay.com/tests/touch" },
    { "@type": "ListItem", "position": 2, "name": "Dead Pixel Check", "url": "https://testmydislay.com/tests/dead-pixel" },
    { "@type": "ListItem", "position": 3, "name": "Refresh Rate Test", "url": "https://testmydislay.com/tests/refresh-rate" },
    { "@type": "ListItem", "position": 4, "name": "Backlight Bleed Test", "url": "https://testmydislay.com/tests/backlight-bleed" },
    { "@type": "ListItem", "position": 5, "name": "Response Time Test", "url": "https://testmydislay.com/tests/response-time" },
    { "@type": "ListItem", "position": 6, "name": "Multi Touch Test", "url": "https://testmydislay.com/tests/multi-touch" }
  ]
};

const touchIcon = `<svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9.5 14.5V8a2.5 2.5 0 0 0 5 0v6.5"/><path d="M7 14.5h10a5 2 0 0 1-10 0z"/></svg>`;
const deadPixelIcon = `<svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/><rect x="10" y="8" width="4" height="4" rx="0.5" fill="currentColor" stroke="none"/></svg>`;
const multiTouchIcon = `<svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="7" cy="7" r="2.5"/><circle cx="17" cy="7" r="2.5"/><circle cx="12" cy="17" r="2.5"/><path d="M7 9.5v3M17 9.5v3M12 14.5v-3"/></svg>`;
const refreshRateIcon = `<svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="16" cy="12" r="3"/><path d="M3 8h7M3 12h5M3 16h7"/></svg>`;
const responseTimeIcon = `<svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="13" r="8"/><path d="M12 9v4l2.5 2.5"/><path d="M9 2h6M12 2v2.5"/><path d="M19.5 5l1-1"/></svg>`;
const backlightIcon = `<svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l6.5 9a7.5 7.5 0 1 1-13 0L12 3z"/></svg>`;


const tests = [
  {
    title: 'Touch Screen Test',
    description: '',
    href: '/tests/touch',
    icon: touchIcon,
   
  },
  {
    title: 'Multi Touch Test',
    description: 'Test how many simultaneous touch points your screen accurately tracks.',
    href: '/tests/multi-touch',
    icon: multiTouchIcon,
  },
  {
    title: 'Dead Pixel Test',
    description: 'Cycle through solid colors to spot pixels that never change (dead pixels).',
    href: '/tests/dead-pixel',
    icon: deadPixelIcon,
  },
  {
    title: 'Backlight Bleed Test',
    description: 'In a dark room, check for light leaking from the edges of your display.',
    href: '/tests/backlight-bleed',
    icon: backlightIcon,
  },
  {
    title: 'Refresh Rate Test',
    description: 'Measure your display\'s actual refresh rate using frame-timing animation.',
    href: '/tests/refresh-rate',
    icon: refreshRateIcon,
  },
  {
    title: 'Response Time Test',
    description: 'Visually measure pixel response time and ghosting on your display.',
    href: '/tests/response-time',
    icon: responseTimeIcon,
  },
];
---

<Layout
  title={seoTitle}
  description={seoDescription}
  keywords={seoKeywords}
  ogType="website"
  canonical="https://testmydislay.com/"
  jsonLd={[homeJsonLd, breadcrumbJsonLd]}
  bodyClass="home-page"
>
  <!-- Hero Section -->
