    color: var(--accent);
    display: block;
  }

  .hero-body {
    font-size: 19px;
    line-height: 30px;
    color: var(--text-body);
    margin: 0 auto 40px;
    max-width: 560px;
    font-weight: 400;
  }

  .hero-actions {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 14px;
    flex-wrap: wrap;
    margin-bottom: 64px;
  }

  .device-stats {
    display: inline-flex;
    align-items: center;
    gap: 0;
    background: var(--bg);
    border: 1.5px solid var(--border);
    border-radius: 12px;
    padding: 0;
    box-shadow: var(--card-shadow);
    overflow: hidden;
    position: relative;
  }

  .device-stats::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 12px;
    border: 1px solid var(--accent-border);
    pointer-events: none;
    z-index: 1;
  }

  .stat-item {
    display: flex;
