---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Display Report — Test My Display" description="Get a comprehensive overview of your display's capabilities and specifications.">
  <div class="page">
    <div class="page-inner">
      <div class="page-header">
        <span class="mono-label">Display Report</span>
        <h1 class="page-title">Your display at a glance.</h1>
        <p class="page-desc">Real-time specs and capabilities detected from your browser. No software required.</p>
      </div>

      <!-- Specs Grid -->
      <div class="specs-grid" id="specs-grid">
        <div class="spec-card">
          <div class="spec-icon" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
              <rect x="1" y="3" width="16" height="11" rx="1.5" stroke="currentColor" stroke-width="1.5" fill="none"/>
              <path d="M5 14l1 3h6l1-3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <div class="spec-body">
            <div class="spec-label">Screen Resolution</div>
            <div class="spec-value" id="spec-res">Detecting…</div>
            <div class="spec-note" id="spec-res-note"></div>
          </div>
        </div>

        <div class="spec-card">
          <div class="spec-icon" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
              <circle cx="9" cy="9" r="7" stroke="currentColor" stroke-width="1.5" fill="none"/>
              <circle cx="9" cy="9" r="2" stroke="currentColor" stroke-width="1.5" fill="none"/>
            </svg>
          </div>
          <div class="spec-body">
            <div class="spec-label">Device Pixel Ratio</div>
            <div class="spec-value" id="spec-dpr">Detecting…</div>
            <div class="spec-note" id="spec-dpr-note"></div>
          </div>
        </div>

        <div class="spec-card">
          <div class="spec-icon" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
              <rect x="2" y="5" width="14" height="8" rx="1" stroke="currentColor" stroke-width="1.5" fill="none"/>
              <path d="M5 9h1M9 9h1M13 9h1" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
          </div>
          <div class="spec-body">
            <div class="spec-label">Color Depth</div>
            <div class="spec-value" id="spec-color">Detecting…</div>
            <div class="spec-note" id="spec-color-note"></div>
          </div>
        </div>

        <div class="spec-card">
          <div class="spec-icon" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
              <circle cx="9" cy="9" r="6" stroke="currentColor" stroke-width="1.5" fill="none"/>
              <path d="M9 5v4l2.5 2.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <div class="spec-body">
            <div class="spec-label">Refresh Rate</div>
            <div class="spec-value" id="spec-fps">Measuring…</div>
            <div class="spec-note" id="spec-fps-note"></div>
          </div>
        </div>

        <div class="spec-card">
          <div class="spec-icon" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
              <path d="M9 4 C7 4 6 5.5 6 7 L6 11 C6 13 7.5 14 9 14 C10.5 14 12 13 12 11 L12 8 C12 7 11.5 6 10.5 6" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round"/>
              <path d="M9 4 L9 7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </div>
          <div class="spec-body">
            <div class="spec-label">Touch Support</div>
            <div class="spec-value" id="spec-touch">Detecting…</div>
            <div class="spec-note" id="spec-touch-note"></div>
          </div>
        </div>

        <div class="spec-card">
          <div class="spec-icon" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
              <rect x="2" y="2" width="14" height="14" rx="2" stroke="currentColor" stroke-width="1.5" fill="none"/>
              <path d="M6 6h6M6 9h6M6 12h4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </div>
          <div class="spec-body">
            <div class="spec-label">Viewport Size</div>
            <div class="spec-value" id="spec-viewport">Detecting…</div>
            <div class="spec-note" id="spec-viewport-note"></div>
          </div>
        </div>

        <div class="spec-card">
          <div class="spec-icon" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
              <path d="M9 2 L9 5 M9 13 L9 16 M2 9 L5 9 M13 9 L16 9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              <rect x="6" y="6" width="6" height="6" rx="1" stroke="currentColor" stroke-width="1.5" fill="none"/>
            </svg>
          </div>
          <div class="spec-body">
            <div class="spec-label">Orientation</div>
            <div class="spec-value" id="spec-orient">Detecting…</div>
            <div class="spec-note" id="spec-orient-note"></div>
          </div>
        </div>

        <div class="spec-card">
          <div class="spec-icon" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
              <path d="M9 2 L14 14 L9 12 L4 14 Z" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linejoin="round"/>
            </svg>
          </div>
          <div class="spec-body">
            <div class="spec-label">HDR Support</div>
            <div class="spec-value" id="spec-hdr">Detecting…</div>
            <div class="spec-note" id="spec-hdr-note"></div>
          </div>
        </div>
      </div>

      <!-- Run all tests CTA -->
      <div class="run-all-cta">
        <h2 class="cta-title">Run all display tests</h2>
        <p class="cta-desc">Go beyond specs — verify your display's actual performance with our hands-on tests.</p>
        <a href="/#tests" class="btn-cta">Browse All Tests</a>
      </div>
    </div>
  </div>
</Layout>

<script>
  function setSpec(id: string, value: string, note = '') {
    const el = document.getElementById(id);
    const noteEl = document.getElementById(id + '-note');
    if (el) el.textContent = value;
    if (noteEl && note) noteEl.textContent = note;
  }

  function detectSpecs() {
    setSpec('spec-res',
      `${screen.width} × ${screen.height}`,
      `Physical: ${Math.round(screen.width * devicePixelRatio)} × ${Math.round(screen.height * devicePixelRatio)} px`
    );

    const dpr = window.devicePixelRatio;
    setSpec('spec-dpr',
      `${dpr}×`,
      dpr >= 2 ? 'Retina / HiDPI display' : dpr >= 1.5 ? 'Mid-density display' : 'Standard density display'
    );

    setSpec('spec-color',
      `${screen.colorDepth}-bit`,
      screen.colorDepth >= 30 ? '10-bit+ color (wide gamut)' : screen.colorDepth === 24 ? '16.7M colors (standard)' : 'Limited color depth'
    );

    const tp = navigator.maxTouchPoints;
    setSpec('spec-touch',
      tp > 0 ? `${tp} points` : 'Not supported',
      tp > 5 ? 'Full multi-touch support' : tp > 0 ? 'Basic touch support' : 'Mouse/pointer only'
    );

    setSpec('spec-viewport',
      `${window.innerWidth} × ${window.innerHeight}`,
      `Available: ${screen.availWidth} × ${screen.availHeight}`
    );

    const orient = screen.orientation?.type || (window.innerWidth > window.innerHeight ? 'landscape-primary' : 'portrait-primary');
    setSpec('spec-orient',
      orient.includes('landscape') ? 'Landscape' : 'Portrait',
      orient
    );

    const hdr = window.matchMedia('(dynamic-range: high)').matches;
    setSpec('spec-hdr',
      hdr ? 'Supported' : 'Not detected',
      hdr ? 'High dynamic range display detected' : 'Standard dynamic range'
    );

    let frames = 0;
    let last = performance.now();
    function measureFPS(now: number) {
      frames++;
      if (now - last >= 1000) {
        setSpec('spec-fps',
          `~${frames} Hz`,
          frames >= 120 ? 'High refresh rate display' : frames >= 90 ? '90Hz display' : frames >= 60 ? '60Hz standard' : 'Low refresh rate'
        );
        return;
      }
      requestAnimationFrame(measureFPS);
    }
    requestAnimationFrame(measureFPS);
  }

  detectSpecs();

  window.addEventListener('resize', () => {
    const vpEl = document.getElementById('spec-viewport');
    if (vpEl) vpEl.textContent = `${window.innerWidth} × ${window.innerHeight}`;
  });
</script>

<style>
  .page {
    padding: 64px 24px 96px;
  }

  .page-inner {
    max-width: 960px;
    margin: 0 auto;
  }

  .page-header {
    max-width: 560px;
    margin-bottom: 48px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .mono-label {
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 12px;
    color: var(--text-mute);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .page-title {
    font-size: 36px;
    font-weight: 600;
    color: var(--text);
    margin: 0;
    letter-spacing: -1.5px;
    line-height: 1.1;
  }

  .page-desc {
    font-size: 16px;
    line-height: 24px;
    color: var(--text-body);
    margin: 0;
  }

  .specs-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 12px;
    margin-bottom: 48px;
  }

  .spec-card {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 20px;
    box-shadow: var(--card-shadow);
    transition: box-shadow 0.2s ease, border-color 0.2s ease, background-color 0.2s ease;
  }
  .spec-card:hover {
    box-shadow: var(--card-shadow-hover);
    border-color: var(--border-strong);
  }

  .spec-icon {
    width: 36px;
    height: 36px;
    border-radius: 8px;
    background: var(--bg-soft);
    border: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: var(--text-body);
  }

  .spec-body {
    flex: 1;
    min-width: 0;
  }

  .spec-label {
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 10px;
    color: var(--text-mute);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 4px;
  }

  .spec-value {
    font-size: 20px;
    font-weight: 600;
    color: var(--text);
    letter-spacing: -0.5px;
    font-variant-numeric: tabular-nums;
    margin-bottom: 2px;
  }

  .spec-note {
    font-size: 12px;
    color: var(--text-mute);
    line-height: 16px;
  }

  .run-all-cta {
    background: var(--text);
    border-radius: 16px;
    padding: 40px 48px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 16px;
  }

  .cta-title {
    font-size: 24px;
    font-weight: 600;
    color: var(--bg);
    margin: 0;
    letter-spacing: -0.8px;
  }

  .cta-desc {
    font-size: 15px;
    line-height: 22px;
    color: var(--bg-soft-2);
    margin: 0;
    opacity: 0.7;
  }

  .btn-cta {
    display: inline-flex;
    align-items: center;
    background: var(--bg);
    color: var(--text);
    font-size: 14px;
    font-weight: 500;
    padding: 0 20px;
    height: 40px;
    border-radius: 9999px;
    text-decoration: none;
    transition: opacity 0.15s;
  }
  .btn-cta:hover { opacity: 0.85; }

  @media (max-width: 600px) {
    .run-all-cta { padding: 28px 24px; }
  }
</style>
