---
import Layout from '../../layouts/Layout.astro';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Backlight Bleed Test — Check IPS Glow & Bleed Online",
  "url": "https://testmydislay.com/tests/backlight-bleed",
  "applicationCategory": "UtilitiesApplication",
  "operatingSystem": "All",
  "description": "Free backlight bleed test online. Fill your screen with pure black to reveal backlight bleeding and IPS glow on LCD, VA, and IPS monitors and laptop screens.",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
};
---

<Layout
  title="Backlight Bleed Test — Check IPS Glow & Bleed Online | TestMyDisplay"
  description="Free backlight bleed test. Fill your screen with pure black to reveal light leaking from the edges of your LCD, IPS, or VA monitor. Works on all displays online."
  keywords="backlight bleed test, ips glow test, monitor display test, screen display test, display test online, backlight bleeding, screen test"
  canonical="https://testmydislay.com/tests/backlight-bleed"
  ogType="website"
  jsonLd={jsonLd}
  noFooter={true}
>

  <!-- ── Header bar (matches test-page pattern) ─────────────────────── -->
  <header class="test-header">
    <div class="test-header-inner">
      <a href="/" class="back-link">
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M10 3L5 8l5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        All Tests
      </a>

      <div class="test-meta">
        <h1 class="test-title">
          Backlight Bleed Test
        </h1>
      </div>

      
    </div>
  </header>

  <!-- ── Content area ────────────────────────────────────────────────── -->
  <div class="content-area">
    <div class="content-inner">

      <!-- Warning -->
      <div class="warning-card" role="alert">
        <div class="warning-icon" aria-hidden="true">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
            <path d="M8 1l7 13H1L8 1z" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linejoin="round"/>
            <path d="M8 6v4M8 11v1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </div>
        <div>
          <strong>Do this in a dark room.</strong> Backlight bleed is only visible when ambient
          light is low. Turn off or dim your lights before starting.
        </div>
      </div>

      <!-- What to look for — full width, horizontal, headings only -->
      <div class="info-card">
        <h2 class="info-card-title">
          <span class="info-card-label">What to look for</span>
        </h2>
        <div class="type-list-h">
          <div class="type-item-h">
            <div class="type-swatch swatch-bleed" aria-hidden="true"></div>
            <strong>Backlight Bleed</strong>
          </div>
          <div class="type-divider" aria-hidden="true"></div>
          <div class="type-item-h">
            <div class="type-swatch swatch-glow" aria-hidden="true"></div>
            <strong>IPS Glow</strong>
          </div>
          <div class="type-divider" aria-hidden="true"></div>
          <div class="type-item-h">
            <div class="type-swatch swatch-none" aria-hidden="true"></div>
            <strong>No Bleed (OLED / VA)</strong>
          </div>
        </div>
      </div>

      <!-- CTA row -->
      <div class="cta-row">
        <button id="start-test-2" class="btn-start btn-start-lg">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M1 5V1h4M9 1h4v4M13 9v4H9M5 13H1V9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          Start Test
        </button>
      </div>

    </div>
  </div>

  <!-- ── Fullscreen black overlay ────────────────────────────────────── -->
  <div class="black-overlay" id="black-overlay" hidden aria-modal="true" role="dialog" aria-label="Backlight bleed test — pure black screen">
    <div class="overlay-hint" id="overlay-hint">
      <svg width="12" height="12" viewBox="0 0 16 16" fill="none" aria-hidden="true">
        <path d="M1 5V1h4M9 1h4v4M13 9v4H9M5 13H1V9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      Click anywhere or press Esc to exit
    </div>
  </div>

</Layout>

<script>
  const overlay   = document.getElementById('black-overlay')!;
  const hint      = document.getElementById('overlay-hint')!;
  const startBtns = Array.from(
    document.querySelectorAll<HTMLButtonElement>('.btn-start')
  );

  let hintTimer: ReturnType<typeof setTimeout>;

  function showHint() {
    hint.style.opacity = '1';
    clearTimeout(hintTimer);
    hintTimer = setTimeout(() => { hint.style.opacity = '0'; }, 3000);
  }

  function openOverlay() {
    overlay.hidden = false;
    document.documentElement.requestFullscreen().catch(() => {});
    showHint();
  }

  function closeOverlay() {
    overlay.hidden = true;
    clearTimeout(hintTimer);
    if (document.fullscreenElement) document.exitFullscreen().catch(() => {});
  }

  startBtns.forEach(btn => btn.addEventListener('click', openOverlay));

  overlay.addEventListener('click', closeOverlay);

  document.addEventListener('keydown', e => {
    if (e.key === 'Escape' && !overlay.hidden) closeOverlay();
  });

  document.addEventListener('fullscreenchange', () => {
    if (!document.fullscreenElement && !overlay.hidden) overlay.hidden = true;
  });
</script>

<style>
  /* ── Header ──────────────────────────────────────────────────────── */
  .test-header {
    background: var(--bg);
    border-bottom: 1px solid var(--border);
    padding: 0 20px;
    flex-shrink: 0;
    box-shadow: 0 1px 0 var(--border);
  }

  .test-header-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 20px;
    min-height: 70px;
    flex-wrap: wrap;
    padding: 10px 0;
  }

  .back-link {
    display: flex;
    align-items: center;
    gap: 5px;
    font-size: 13px;
    color: var(--text-mute);
    text-decoration: none;
    padding: 6px 10px;
    border-radius: 8px;
    transition: background 0.15s, color 0.15s;
    flex-shrink: 0;
  }
  .back-link:hover {
    background: var(--bg-soft);
    color: var(--text);
  }

  .test-meta {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .test-title {
    font-size: 17px;
    font-weight: 600;
    color: var(--text);
    margin: 0;
    letter-spacing: -0.4px;
    line-height: 1.2;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .test-icon {
    font-size: 18px;
    line-height: 1;
  }

  .test-subtitle {
    font-size: 12px;
    color: var(--text-mute);
    margin: 0;
    line-height: 1.5;
  }

  .header-actions {
    flex-shrink: 0;
  }

  /* ── Start button ─────────────────────────────────────────────────── */
  .btn-start {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    background: var(--accent);
    color: var(--accent-text);
    font-size: 13.5px;
    font-weight: 600;
    padding: 0 18px;
    height: 38px;
    border-radius: var(--radius-full);
    border: none;
    cursor: pointer;
    transition: background-color 0.15s ease;
    white-space: nowrap;
    font-family: inherit;
  }
  .btn-start:hover { background: var(--accent-hover); }

  .btn-start-lg {
    font-size: 15px;
    height: 46px;
    padding: 0 24px;
    gap: 9px;
  }

  /* ── Content area ─────────────────────────────────────────────────── */
  .content-area {
    padding: 40px 20px 60px;
  }

  .content-inner {
    max-width: 780px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  /* ── Warning card ─────────────────────────────────────────────────── */
  .warning-card {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    background: color-mix(in srgb, #f5a623 10%, var(--bg));
    border: 1px solid color-mix(in srgb, #f5a623 45%, transparent);
    border-radius: var(--radius-lg);
    padding: 14px 16px;
    font-size: 14px;
    color: var(--text-body);
    line-height: 1.6;
  }

  .warning-icon {
    width: 28px;
    height: 28px;
    border-radius: 6px;
    background: color-mix(in srgb, #f5a623 18%, var(--bg));
    border: 1px solid color-mix(in srgb, #f5a623 40%, transparent);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #d97706;
    flex-shrink: 0;
    margin-top: 1px;
  }

  [data-theme="dark"] .warning-icon { color: #fbbf24; }

  .warning-card strong {
    color: var(--text);
  }

  .info-card {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 20px 22px;
    box-shadow: var(--card-shadow);
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .info-card-title {
    margin: 0;
  }

  .info-card-label {
    font-family: var(--font-mono, "JetBrains Mono", ui-monospace, monospace);
    font-size: 10px;
    font-weight: 500;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    display: block;
  }

  /* ── Steps list ───────────────────────────────────────────────────── */
  .steps-list {
    margin: 0;
    padding: 0 0 0 20px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .steps-list li {
    font-size: 13.5px;
    line-height: 1.55;
    color: var(--text-body);
  }

  .steps-list strong { color: var(--text); font-weight: 600; }

  kbd {
    font-family: var(--font-mono, "JetBrains Mono", ui-monospace, monospace);
    font-size: 11px;
    background: var(--bg-soft);
    border: 1px solid var(--border);
    border-bottom-width: 2px;
    border-radius: 4px;
    padding: 1px 5px;
    color: var(--text-body);
  }

  /* ── Type list — horizontal ───────────────────────────────────────── */
  .type-list-h {
    display: flex;
    align-items: center;
    gap: 0;
    flex-wrap: wrap;
  }

  .type-item-h {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 6px 20px 6px 0;
    flex: 1;
    min-width: 160px;
  }

  .type-item-h strong {
    font-size: 13.5px;
    font-weight: 600;
    color: var(--text);
    white-space: nowrap;
  }

  .type-divider {
    width: 1px;
    height: 32px;
    background: var(--border);
    flex-shrink: 0;
    margin: 0 20px 0 0;
  }

  .type-swatch {
    width: 36px;
    height: 36px;
    border-radius: 8px;
    flex-shrink: 0;
    border: 1px solid var(--border);
  }

  .swatch-bleed {
    background: linear-gradient(135deg, rgba(255,255,255,0.85) 0%, rgba(200,200,200,0.3) 60%, #111 100%);
  }

  .swatch-glow {
    background: radial-gradient(circle at 25% 25%, rgba(255,255,255,0.55) 0%, rgba(200,200,200,0.1) 50%, #111 100%);
  }

  .swatch-none {
    background: #000;
  }

  /* ── CTA row ──────────────────────────────────────────────────────── */
  .cta-row {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 10px;
  }

  .cta-hint {
    font-size: 12.5px;
    color: var(--text-mute);
    margin: 0;
    line-height: 1.5;
  }

  /* ── Fullscreen overlay ───────────────────────────────────────────── */
  .black-overlay {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: #000;
    cursor: pointer;
  }

  .overlay-hint {
    position: fixed;
    bottom: 32px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    align-items: center;
    gap: 7px;
    background: rgba(255, 255, 255, 0.07);
    border: 1px solid rgba(255, 255, 255, 0.10);
    border-radius: var(--radius-full);
    padding: 8px 18px;
    font-size: 12.5px;
    color: rgba(255, 255, 255, 0.45);
    transition: opacity 0.5s ease;
    white-space: nowrap;
    pointer-events: none;
  }

  /* ── Responsive ───────────────────────────────────────────────────── */
  @media (max-width: 700px) {
    .test-header { padding: 0 14px; }
    .test-header-inner { gap: 12px; }
    .test-subtitle { display: none; }
    .header-actions .btn-start { height: 34px; font-size: 12.5px; padding: 0 14px; }
    .content-area { padding: 28px 14px 48px; }
    .type-item-h { min-width: 140px; padding-right: 14px; }
    .type-divider { margin-right: 14px; }
  }

  @media (max-width: 400px) {
    .test-icon { display: none; }
    .type-divider { display: none; }
    .type-list-h { gap: 10px; }
    .type-item-h { flex: none; width: 100%; padding-right: 0; }
  }
</style>
