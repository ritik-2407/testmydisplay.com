---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Brightness Test — Test My Display" description="Test your display's brightness uniformity and black-level performance." noFooter={true}>
  <div class="page">
    <div class="page-inner">
      <a href="/" class="back-link">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M10 3L5 8l5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        All Tests
      </a>

      <div class="content">
        <div class="header">
          <span class="icon" aria-hidden="true">☀️</span>
          <div>
            <h1 class="title">Brightness Test</h1>
            <p class="subtitle">Check brightness uniformity, black-level depth, and white-level clipping.</p>
          </div>
        </div>

        <!-- Mode selector -->
        <div class="mode-grid">
          {[
            { id: 'pure-white', label: 'Pure White', bg: '#ffffff', border: '#ebebeb', text: '#888' },
            { id: 'pure-black', label: 'Pure Black', bg: '#000000', border: '#333', text: '#666' },
            { id: 'near-black', label: 'Near Black', bg: '#0d0d0d', border: '#222', text: '#555' },
            { id: 'near-white', label: 'Near White', bg: '#f0f0f0', border: '#ddd', text: '#888' },
            { id: 'gray-50', label: '50% Gray', bg: '#808080', border: 'transparent', text: '#555' },
            { id: 'checker', label: 'Checkerboard', bg: 'checkerboard', border: '#ebebeb', text: '#888' },
          ].map(m => (
            <button
              class="mode-card"
              data-mode={m.id}
              data-bg={m.bg}
              style={`background:${m.bg === 'checkerboard' ? '#fff' : m.bg};border:1px solid ${m.border};`}
            >
              {m.bg === 'checkerboard' && (
                <div class="checker-preview" aria-hidden="true"></div>
              )}
              <span class="mode-label" style={`color:${m.text}`}>{m.label}</span>
            </button>
          ))}
        </div>

        <!-- Brightness slider -->
        <div class="slider-control">
          <label class="slider-title">Brightness Level</label>
          <div class="slider-row-inner">
            <span class="slider-end">0%</span>
            <input type="range" id="brightness-slider" min="0" max="100" value="50" class="slider" />
            <span class="slider-end">100%</span>
          </div>
          <div class="slider-value" id="brightness-value">50%</div>
        </div>

        <!-- Preview canvas -->
        <div class="preview-area" id="preview-area">
          <canvas id="brightness-canvas" aria-label="Brightness test preview"></canvas>
          <div class="preview-hint" id="preview-hint">Select a mode above to begin</div>
        </div>

        <button id="fs-btn" class="btn-fs">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 5V1h4M9 1h4v4M13 9v4H9M5 13H1V9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Enter Fullscreen for accurate results
        </button>

        <div class="info-box">
          <h3 class="info-title">What to look for</h3>
          <ul class="info-list">
            <li><strong>Uniformity:</strong> Pure white should look the same brightness in every corner. Darker areas at edges = backlight bleed or clouding.</li>
            <li><strong>Black level:</strong> Pure black should be as dark as possible. Grayish-black = IPS glow or poor contrast.</li>
            <li><strong>Clipping:</strong> Near-black steps should all be visible. If the darkest shades look identical = black crush.</li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</Layout>

<script>
  const canvas = document.getElementById('brightness-canvas') as HTMLCanvasElement;
  const area = document.getElementById('preview-area')!;
  const slider = document.getElementById('brightness-slider') as HTMLInputElement;
  const sliderValueEl = document.getElementById('brightness-value')!;
  const hint = document.getElementById('preview-hint')!;
  const fsBtn = document.getElementById('fs-btn')!;
  const modeCards = document.querySelectorAll('.mode-card');

  let ctx: CanvasRenderingContext2D | null = null;
  let currentMode = '';
  let brightness = 50;

  function resize() {
    canvas.width = area.clientWidth;
    canvas.height = area.clientHeight;
    ctx = canvas.getContext('2d');
    if (currentMode) drawMode(currentMode);
  }

  function hexToRgb(hex: string) {
    const result = /^#?([a-f\d]{2})([a-f\d]{2})([a-f\d]{2})$/i.exec(hex);
    return result ? {
      r: parseInt(result[1], 16),
      g: parseInt(result[2], 16),
      b: parseInt(result[3], 16),
    } : { r: 0, g: 0, b: 0 };
  }

  function adjustBrightness(hex: string, pct: number) {
    const { r, g, b } = hexToRgb(hex);
    const factor = pct / 100;
    return `rgb(${Math.round(r*factor)},${Math.round(g*factor)},${Math.round(b*factor)})`;
  }

  function drawMode(mode: string) {
    if (!ctx) return;
    const w = canvas.width;
    const h = canvas.height;
    ctx.clearRect(0, 0, w, h);

    if (mode === 'checker') {
      const size = 32;
      for (let y = 0; y < h; y += size) {
        for (let x = 0; x < w; x += size) {
          const isWhite = (Math.floor(x/size) + Math.floor(y/size)) % 2 === 0;
          const v = Math.round(255 * brightness / 100);
          ctx.fillStyle = isWhite ? `rgb(${v},${v},${v})` : '#000';
          ctx.fillRect(x, y, size, size);
        }
      }
    } else {
      const hexMap: Record<string, string> = {
        'pure-white': '#ffffff',
        'pure-black': '#000000',
        'near-black': '#0d0d0d',
        'near-white': '#f0f0f0',
        'gray-50': '#808080',
      };
      ctx.fillStyle = adjustBrightness(hexMap[mode] || '#808080', brightness);
      ctx.fillRect(0, 0, w, h);
    }
  }

  modeCards.forEach(card => {
    card.addEventListener('click', () => {
      modeCards.forEach(c => c.classList.remove('selected'));
      card.classList.add('selected');
      currentMode = (card as HTMLElement).dataset.mode!;
      hint.style.display = 'none';
      drawMode(currentMode);
    });
  });

  slider.addEventListener('input', () => {
    brightness = parseInt(slider.value);
    sliderValueEl.textContent = `${brightness}%`;
    if (currentMode) drawMode(currentMode);
  });

  fsBtn.addEventListener('click', () => {
    if (!document.fullscreenElement) {
      canvas.requestFullscreen().catch(() => {});
    } else {
      document.exitFullscreen();
    }
  });

  window.addEventListener('resize', resize);
  resize();
</script>

<style>
  .page {
    padding: 64px 24px;
    min-height: calc(100vh - 64px - 280px);
  }

  .page-inner {
    max-width: 680px;
    margin: 0 auto;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    color: #4d4d4d;
    text-decoration: none;
    padding: 6px 10px;
    border-radius: 6px;
    transition: background 0.15s;
    margin-bottom: 32px;
  }
  .back-link:hover { background: #f5f5f5; color: #171717; }

  .content { display: flex; flex-direction: column; gap: 20px; }
  .header { display: flex; align-items: flex-start; gap: 16px; }
  .icon { font-size: 40px; line-height: 1; flex-shrink: 0; }
  .title {
    font-size: 28px; font-weight: 600; color: #171717;
    margin: 0 0 4px; letter-spacing: -0.8px;
  }
  .subtitle { font-size: 15px; color: #4d4d4d; margin: 0; }

  .mode-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 8px;
  }

  .mode-card {
    position: relative;
    height: 80px;
    border-radius: 10px;
    cursor: pointer;
    overflow: hidden;
    transition: box-shadow 0.15s;
    display: flex;
    align-items: flex-end;
    padding: 8px;
  }
  .mode-card:hover, .mode-card.selected {
    box-shadow: 0 0 0 2px #0070f3;
  }

  .checker-preview {
    position: absolute;
    inset: 0;
    background-image: repeating-conic-gradient(#ccc 0% 25%, #fff 0% 50%);
    background-size: 16px 16px;
  }

  .mode-label {
    position: relative;
    font-size: 11px;
    font-weight: 500;
    z-index: 1;
  }

  .slider-control {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .slider-title {
    font-size: 13px;
    font-weight: 500;
    color: #171717;
  }

  .slider-row-inner {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .slider-end {
    font-family: "JetBrains Mono", monospace;
    font-size: 11px;
    color: #888;
    width: 30px;
  }

  .slider {
    flex: 1;
    height: 4px;
    accent-color: #171717;
    cursor: pointer;
  }

  .slider-value {
    font-family: "JetBrains Mono", monospace;
    font-size: 12px;
    color: #888;
    text-align: right;
  }

  .preview-area {
    position: relative;
    height: 260px;
    background: #0a0a0a;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid #ebebeb;
  }

  #brightness-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .preview-hint {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 14px;
    color: #444;
    pointer-events: none;
  }

  .btn-fs {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: #fff;
    border: 1px solid #ebebeb;
    border-radius: 9999px;
    padding: 0 16px;
    height: 36px;
    font-size: 13px;
    color: #171717;
    cursor: pointer;
    transition: border-color 0.15s;
    align-self: flex-start;
  }
  .btn-fs:hover { border-color: #a1a1a1; }

  .info-box {
    background: #fafafa;
    border: 1px solid #ebebeb;
    border-radius: 12px;
    padding: 20px 24px;
  }

  .info-title {
    font-size: 14px;
    font-weight: 600;
    color: #171717;
    margin: 0 0 10px;
  }

  .info-list {
    margin: 0;
    padding: 0 0 0 18px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .info-list li {
    font-size: 13px;
    line-height: 18px;
    color: #4d4d4d;
  }

  @media (max-width: 500px) {
    .mode-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>
