---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Dead Pixel Test — Test My Display" description="Cycle through solid colors fullscreen to spot dead pixels on your display." noFooter={true}>
  <!-- Instructions view -->
  <div class="page" id="instructions">
    <div class="page-inner">

      <a href="/" class="back-link">
        <svg width="15" height="15" viewBox="0 0 16 16" fill="none"><path d="M10 3L5 8l5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        All Tests
      </a>

      <!-- Hero -->
      <div class="hero">
        <h1 class="page-title">Dead Pixel Test</h1>
        <p class="page-desc">
          This test fills your screen with solid colors so any dead pixels become immediately visible.
        </p>
        <div class="cta-row">
          <button id="start-test" class="btn-start" aria-label="Start dead pixel test in fullscreen">
            <svg width="15" height="15" viewBox="0 0 16 16" fill="none"><path d="M1 5V1h4M9 1h4v4M13 9v4H9M5 13H1V9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Start Test
          </button>
        </div>
      </div>

      <!-- Color strip preview -->
      {/* <div class="color-strip-wrap">
        <p class="strip-label">Test colors</p>
        <div class="color-strip">
          {[
            { hex: '#000000', name: 'Black' },
            { hex: '#ffffff', name: 'White' },
            { hex: '#ff0000', name: 'Red' },
            { hex: '#00ff00', name: 'Green' },
            { hex: '#0000ff', name: 'Blue' },
            { hex: '#ff00ff', name: 'Magenta' },
            { hex: '#ffff00', name: 'Yellow' },
            { hex: '#00ffff', name: 'Cyan' },
          ].map(c => (
            <div class="strip-swatch" style={`background:${c.hex}`} title={c.name} aria-label={c.name}></div>
          ))}
        </div>
      </div> */}

      <!-- Instructions card -->
      <div class="info-card">
        <h2 class="card-title">How to test</h2>
        <ol class="steps-list">
          <li>
            <span class="step-num">1</span>
            <span>Click <strong>Start Test</strong> to enter fullscreen.</span>
          </li>
          <li>
            <span class="step-num">2</span>
            <span>Click / tap anywhere or press <kbd>→</kbd> to cycle through colors.</span>
          </li>
          <li>
            <span class="step-num">3</span>
            <span>Look carefully for any pixel that doesn't match the screen color.</span>
          </li>
          <li>
            <span class="step-num">4</span>
            <span>A permanent black dot on any color = dead pixel.</span>
          </li>
          <li>
            <span class="step-num">5</span>
            <span>Press <kbd>Esc</kbd> or click <strong>Exit</strong> when done.</span>
          </li>
        </ol>
      </div>

    </div>
  </div>

  <!-- Fullscreen test overlay -->
  <div class="test-overlay" id="test-overlay" role="application" aria-label="Dead pixel test" hidden>
    <!-- Bottom HUD: hint + exit -->
    <div class="bottom-hud" id="bottom-hud">
      <span class="hud-hint">Click / tap or <kbd class="dark-kbd">→</kbd> to change color</span>
      <button id="exit-test" class="exit-btn" aria-label="Exit test">
        <svg width="12" height="12" viewBox="0 0 14 14" fill="none"><path d="M1 1l12 12M13 1L1 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        Exit
      </button>
    </div>
  </div>
</Layout>

<script>
  const colors = [
    { hex: '#000000', name: 'Black' },
    { hex: '#ffffff', name: 'White' },
    { hex: '#ff0000', name: 'Red' },
    { hex: '#00ff00', name: 'Green' },
    { hex: '#0000ff', name: 'Blue' },
    { hex: '#ff00ff', name: 'Magenta' },
    { hex: '#ffff00', name: 'Yellow' },
    { hex: '#00ffff', name: 'Cyan' },
  ];

  let currentIndex = 0;

  const overlay   = document.getElementById('test-overlay')!;
  const startBtn  = document.getElementById('start-test')!;
  const exitBtn   = document.getElementById('exit-test')!;
  const bottomHud = document.getElementById('bottom-hud')!;

  function isLight(hex: string) {
    const r = parseInt(hex.slice(1,3),16);
    const g = parseInt(hex.slice(3,5),16);
    const b = parseInt(hex.slice(5,7),16);
    return (r*299 + g*587 + b*114) / 1000 > 128;
  }

  function setColor(index: number) {
    currentIndex = index;
    const c = colors[index];
    overlay.style.backgroundColor = c.hex;

    const light = isLight(c.hex);
    const hudAlpha  = light ? 'rgba(0,0,0,0.55)'   : 'rgba(255,255,255,0.12)';
    const hudText   = light ? 'rgba(0,0,0,0.75)'    : 'rgba(255,255,255,0.75)';
    const hudBorder = light ? 'rgba(0,0,0,0.12)'    : 'rgba(255,255,255,0.15)';

    bottomHud.style.setProperty('--hud-bg',     hudAlpha);
    bottomHud.style.setProperty('--hud-text',   hudText);
    bottomHud.style.setProperty('--hud-border', hudBorder);
  }

  function showHudTemporarily() {
    bottomHud.style.opacity = '1';
    clearTimeout((bottomHud as any)._t);
    (bottomHud as any)._t = setTimeout(() => {
      bottomHud.style.opacity = '0';
    }, 2800);
  }

  function startTest() {
    overlay.hidden = false;
    setColor(0);
    showHudTemporarily();
    document.documentElement.requestFullscreen().catch(() => {});
  }

  function exitTest() {
    overlay.hidden = true;
    if (document.fullscreenElement) document.exitFullscreen().catch(() => {});
  }

  overlay.addEventListener('click', e => {
    if (e.target === overlay) {
      currentIndex = (currentIndex + 1) % colors.length;
      setColor(currentIndex);
      showHudTemporarily();
    }
  });

  overlay.addEventListener('mousemove', () => showHudTemporarily());

  document.addEventListener('keydown', e => {
    if (overlay.hidden) return;
    if (e.key === 'ArrowRight' || e.key === ' ') {
      e.preventDefault();
      currentIndex = (currentIndex + 1) % colors.length;
      setColor(currentIndex);
      showHudTemporarily();
    } else if (e.key === 'ArrowLeft') {
      e.preventDefault();
      currentIndex = (currentIndex - 1 + colors.length) % colors.length;
      setColor(currentIndex);
      showHudTemporarily();
    } else if (e.key === 'Escape') {
      exitTest();
    }
  });

  document.addEventListener('fullscreenchange', () => {
    if (!document.fullscreenElement && !overlay.hidden) exitTest();
  });

  startBtn.addEventListener('click', startTest);
  exitBtn.addEventListener('click', e => { e.stopPropagation(); exitTest(); });
</script>

<style>
  /* ── Page layout ── */
  .page {
    padding: 56px 24px 80px;
    min-height: calc(100vh - 64px - 280px);
  }

  .page-inner {
    max-width: 680px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  /* ── Back link ── */
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    color: var(--text-mute);
    text-decoration: none;
    padding: 5px 10px;
    border-radius: 6px;
    transition: background 0.15s, color 0.15s;
    align-self: flex-start;
  }
  .back-link:hover {
    background: var(--bg);
    color: var(--text);
  }

  /* ── Hero ── */
  .hero {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-size: 12px;
    font-weight: 500;
    color: var(--accent);
    font-family: var(--font-mono, monospace);
    text-transform: uppercase;
    letter-spacing: 0.07em;
  }

  .badge-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--accent);
    flex-shrink: 0;
  }

  .page-title {
    font-size: clamp(28px, 5vw, 40px);
    font-weight: 700;
    color: var(--text);
    margin: 0;
    letter-spacing: -1.2px;
    line-height: 1.1;
  }

  .page-desc {
    font-size: 15px;
    line-height: 1.65;
    color: var(--text-body);
    margin: 0;
    max-width: 560px;
  }

  /* ── Color strip ── */
  .color-strip-wrap {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .strip-label {
    font-size: 11px;
    font-weight: 500;
    color: var(--text-mute);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0;
    font-family: var(--font-mono, monospace);
  }

  .color-strip {
    display: flex;
    gap: 0;
    border-radius: 10px;
    overflow: hidden;
    border: 1px solid var(--border);
    height: 48px;
  }

  .strip-swatch {
    flex: 1;
    transition: flex 0.2s ease;
    cursor: default;
  }
  .strip-swatch:hover { flex: 1.6; }

  /* ── Info card ── */
  .info-card {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 22px 24px;
    box-shadow: var(--card-shadow);
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .card-title {
    font-size: 13px;
    font-weight: 600;
    color: var(--text);
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-family: var(--font-mono, monospace);
  }

  /* Steps */
  .steps-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 11px;
  }

  .steps-list li {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 13.5px;
    line-height: 1.55;
    color: var(--text-body);
  }

  .steps-list li strong { color: var(--text); }

  .step-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
    min-width: 20px;
    border-radius: 50%;
    background: var(--accent-dim);
    border: 1px solid var(--accent-border);
    color: var(--accent);
    font-size: 10px;
    font-weight: 700;
    font-family: var(--font-mono, monospace);
    margin-top: 1px;
  }

  kbd {
    font-family: var(--font-mono, monospace);
    font-size: 10.5px;
    background: var(--bg-soft);
    border: 1px solid var(--border-strong);
    border-radius: 4px;
    padding: 1px 5px;
    color: var(--text);
  }

  /* ── CTA ── */
  .cta-row {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
  }

  .btn-start {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--accent);
    color: var(--accent-text);
    font-size: 14px;
    font-weight: 600;
    padding: 0 22px;
    height: 44px;
    border-radius: 9999px;
    border: none;
    cursor: pointer;
    transition: background-color 0.15s;
    white-space: nowrap;
  }
  .btn-start:hover { background: var(--accent-hover); }

  .cta-hint {
    font-size: 12.5px;
    color: var(--text-mute);
    margin: 0;
  }

  /* ── Fullscreen overlay ── */
  .test-overlay {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: #000;
    cursor: pointer;
    overflow: hidden;
    transition: background-color 0.18s ease;
  }

  /* ── Bottom HUD ── */
  .bottom-hud {
    position: fixed;
    bottom: 24px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    align-items: center;
    gap: 14px;
    background: var(--hud-bg, rgba(255,255,255,0.12));
    border: 1px solid var(--hud-border, rgba(255,255,255,0.15));
    border-radius: 9999px;
    padding: 7px 14px;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    transition: opacity 0.4s ease;
    pointer-events: all;
    white-space: nowrap;
  }

  .hud-hint {
    font-size: 12.5px;
    color: var(--hud-text, rgba(255,255,255,0.75));
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .dark-kbd {
    font-family: var(--font-mono, monospace);
    font-size: 10px;
    background: var(--hud-bg, rgba(255,255,255,0.15));
    border: 1px solid var(--hud-border, rgba(255,255,255,0.2));
    border-radius: 4px;
    padding: 1px 5px;
    color: var(--hud-text, rgba(255,255,255,0.8));
  }

  .exit-btn {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    background: transparent;
    border: 1px solid var(--hud-border, rgba(255,255,255,0.2));
    border-radius: 6px;
    padding: 4px 10px;
    font-size: 12px;
    color: var(--hud-text, rgba(255,255,255,0.8));
    cursor: pointer;
    transition: background 0.15s;
  }
  .exit-btn:hover { background: var(--hud-bg, rgba(255,255,255,0.2)); }
</style>
