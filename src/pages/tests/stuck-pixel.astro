---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Stuck Pixel Fixer — Test My Display" description="Rapidly flash colors to potentially fix stuck or frozen pixels on your display." noFooter={true}>
  <div class="page">
    <div class="page-inner">
      <a href="/" class="back-link">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M10 3L5 8l5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        All Tests
      </a>

      <div class="content">
        <div class="header">
          <span class="icon" aria-hidden="true">⚡</span>
          <div>
            <h1 class="title">Stuck Pixel Fixer</h1>
            <p class="subtitle">Rapidly flash colors to coax stuck pixels back to life.</p>
          </div>
        </div>

        <div class="info-card">
          <h2 class="info-title">What's a stuck pixel?</h2>
          <p class="info-body">Unlike dead pixels (permanently off), stuck pixels are frozen on a specific color — usually red, green, or blue. Rapid color cycling can sometimes "unstick" them by forcing the pixel's transistor to switch states repeatedly.</p>
          <p class="info-body"><strong>Note:</strong> Results are not guaranteed. This method works on some displays but not all. Run the fixer for at least 10–30 minutes on the affected area for best results.</p>
        </div>

        <!-- Controls -->
        <div class="controls">
          <div class="control-group">
            <label class="ctrl-label" for="speed-slider">Flash Speed</label>
            <div class="slider-row">
              <span class="slider-hint">Slow</span>
              <input type="range" id="speed-slider" min="1" max="10" value="5" class="slider" />
              <span class="slider-hint">Fast</span>
            </div>
            <span class="speed-value" id="speed-value">50ms</span>
          </div>

          <div class="control-group">
            <label class="ctrl-label">Area</label>
            <div class="area-options">
              <label class="area-opt">
                <input type="radio" name="area" value="fullscreen" checked />
                <span>Full Screen</span>
              </label>
              <label class="area-opt">
                <input type="radio" name="area" value="region" />
                <span>Draw Region</span>
              </label>
            </div>
          </div>
        </div>

        <div class="cta-row">
          <button id="start-btn" class="btn-start-test">
            Start Fixer
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M5 3l8 5-8 5V3z" fill="currentColor"/></svg>
          </button>
          <span class="cta-note">Will enter fullscreen</span>
        </div>

        <!-- Timer display -->
        <div class="timer-display" id="timer-display" hidden>
          <div class="timer-label">Running for</div>
          <div class="timer-value" id="timer-value">00:00</div>
          <div class="timer-note">Keep running for 10–30 minutes</div>
        </div>
      </div>
    </div>
  </div>

  <!-- Fullscreen fixer overlay -->
  <div class="fixer-overlay" id="fixer-overlay" hidden>
    <div class="fixer-controls" id="fixer-controls">
      <span id="fixer-elapsed">00:00</span>
      <button id="stop-btn" class="exit-btn">
        <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><rect x="2" y="2" width="8" height="8" rx="1" fill="currentColor"/></svg>
        Stop
      </button>
    </div>
  </div>
</Layout>

<script>
  const colors = ['#ff0000','#00ff00','#0000ff','#ff00ff','#ffff00','#00ffff','#ffffff','#000000'];
  let intervalId: ReturnType<typeof setInterval> | null = null;
  let colorIndex = 0;
  let startTime: number | null = null;
  let timerInterval: ReturnType<typeof setInterval> | null = null;

  const startBtn = document.getElementById('start-btn')!;
  const stopBtn = document.getElementById('stop-btn')!;
  const overlay = document.getElementById('fixer-overlay')!;
  const speedSlider = document.getElementById('speed-slider') as HTMLInputElement;
  const speedValue = document.getElementById('speed-value')!;
  const timerDisplay = document.getElementById('timer-display')!;
  const timerValue = document.getElementById('timer-value')!;
  const fixerElapsed = document.getElementById('fixer-elapsed')!;

  function getSpeed() {
    const v = parseInt(speedSlider.value);
    return Math.round(1000 / (v * v));
  }

  function formatTime(ms: number) {
    const s = Math.floor(ms / 1000);
    const m = Math.floor(s / 60);
    return `${String(m).padStart(2,'0')}:${String(s % 60).padStart(2,'0')}`;
  }

  speedSlider.addEventListener('input', () => {
    speedValue.textContent = `${getSpeed()}ms`;
    if (intervalId) {
      clearInterval(intervalId);
      intervalId = setInterval(flash, getSpeed());
    }
  });

  function flash() {
    overlay.style.backgroundColor = colors[colorIndex % colors.length];
    colorIndex++;
  }

  function startFixer() {
    overlay.hidden = false;
    flash();
    intervalId = setInterval(flash, getSpeed());

    startTime = Date.now();
    timerDisplay.hidden = false;

    timerInterval = setInterval(() => {
      const elapsed = Date.now() - startTime!;
      const formatted = formatTime(elapsed);
      timerValue.textContent = formatted;
      fixerElapsed.textContent = formatted;
    }, 1000);

    document.documentElement.requestFullscreen().catch(() => {});
  }

  function stopFixer() {
    if (intervalId) clearInterval(intervalId);
    if (timerInterval) clearInterval(timerInterval);
    intervalId = null;
    timerInterval = null;
    overlay.hidden = true;
    if (document.fullscreenElement) document.exitFullscreen().catch(() => {});
  }

  startBtn.addEventListener('click', startFixer);
  stopBtn.addEventListener('click', stopFixer);

  document.addEventListener('fullscreenchange', () => {
    if (!document.fullscreenElement && !overlay.hidden) {
      stopFixer();
    }
  });

  document.addEventListener('keydown', e => {
    if (e.key === 'Escape' && !overlay.hidden) stopFixer();
  });

  speedValue.textContent = `${getSpeed()}ms`;
</script>

<style>
  .page {
    padding: 64px 24px;
    min-height: calc(100vh - 64px - 280px);
  }

  .page-inner {
    max-width: 600px;
    margin: 0 auto;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    color: #4d4d4d;
    text-decoration: none;
    padding: 6px 10px;
    border-radius: 6px;
    transition: background 0.15s;
    margin-bottom: 32px;
  }
  .back-link:hover { background: #f5f5f5; color: #171717; }

  .content {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .header {
    display: flex;
    align-items: flex-start;
    gap: 16px;
  }

  .icon { font-size: 40px; line-height: 1; flex-shrink: 0; }

  .title {
    font-size: 28px;
    font-weight: 600;
    color: #171717;
    margin: 0 0 4px;
    letter-spacing: -0.8px;
  }

  .subtitle {
    font-size: 15px;
    color: #4d4d4d;
    margin: 0;
  }

  .info-card {
    background: #fafafa;
    border: 1px solid #ebebeb;
    border-radius: 12px;
    padding: 20px 24px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .info-title {
    font-size: 14px;
    font-weight: 600;
    color: #171717;
    margin: 0;
  }

  .info-body {
    font-size: 14px;
    line-height: 20px;
    color: #4d4d4d;
    margin: 0;
  }

  .controls {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .control-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ctrl-label {
    font-size: 13px;
    font-weight: 500;
    color: #171717;
  }

  .slider-row {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .slider-hint {
    font-size: 12px;
    color: #888;
    white-space: nowrap;
  }

  .slider {
    flex: 1;
    height: 4px;
    accent-color: #171717;
    cursor: pointer;
  }

  .speed-value {
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 12px;
    color: #888;
  }

  .area-options {
    display: flex;
    gap: 12px;
  }

  .area-opt {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 14px;
    color: #4d4d4d;
    cursor: pointer;
  }

  .cta-row {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .btn-start-test {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #171717;
    color: #fff;
    font-size: 15px;
    font-weight: 500;
    padding: 0 20px;
    height: 44px;
    border-radius: 9999px;
    border: none;
    cursor: pointer;
    transition: opacity 0.15s;
  }
  .btn-start-test:hover { opacity: 0.85; }

  .cta-note {
    font-size: 12px;
    color: #888;
  }

  .timer-display {
    background: #fff;
    border: 1px solid #ebebeb;
    border-radius: 12px;
    padding: 20px 24px;
    text-align: center;
  }

  .timer-label {
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 11px;
    color: #888;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 8px;
  }

  .timer-value {
    font-size: 40px;
    font-weight: 600;
    color: #171717;
    font-variant-numeric: tabular-nums;
    letter-spacing: -1px;
    margin-bottom: 4px;
  }

  .timer-note {
    font-size: 12px;
    color: #888;
  }

  /* Fullscreen overlay */
  .fixer-overlay {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: #ff0000;
    transition: background-color 0.05s linear;
  }

  .fixer-controls {
    position: fixed;
    top: 24px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    align-items: center;
    gap: 16px;
    background: rgba(0,0,0,0.6);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 9999px;
    padding: 8px 16px;
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 14px;
    color: rgba(255,255,255,0.9);
    font-variant-numeric: tabular-nums;
  }

  .exit-btn {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    background: rgba(255,255,255,0.15);
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: 6px;
    padding: 4px 10px;
    font-size: 12px;
    color: rgba(255,255,255,0.9);
    cursor: pointer;
    transition: background 0.15s;
  }
  .exit-btn:hover { background: rgba(255,255,255,0.25); }
</style>
